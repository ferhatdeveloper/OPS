## Veritabanı Güvenlik ve Koruma Kuralları
database_security {
    data_protection: {
        existing_data: {
            preserve_device_data: true;
            backup_before_changes: true;
            isolation_level: "READ_COMMITTED";
            prevent_data_loss: true;
            data_integrity_checks: true;
        };

        access_control: {
            schema_level_security: true;
            row_level_security: true;
            column_level_encryption: true;
            audit_logging: true;
        };

        sync_rules: {
            conflict_resolution: "device_wins";
            merge_strategy: "preserve_local";
            sync_direction: "device_to_server";
            version_control: true;
        };

        backup_strategy: {
            auto_backup: {
                frequency: "daily";
                retention_period: "30_days";
                compression: true;
                encryption: true;
            };
            manual_backup: {
                before_sync: true;
                before_schema_change: true;
                before_data_migration: true;
            };
            restore_points: {
                keep_daily: 7;
                keep_weekly: 4;
                keep_monthly: 3;
            };
        };

        data_validation: {
            schema_validation: true;
            data_type_checking: true;
            constraint_checking: true;
            referential_integrity: true;
        };

        error_handling: {
            rollback_on_error: true;
            transaction_isolation: true;
            error_logging: true;
            notification_on_error: true;
        };
    };

    local_storage: {
        hive: {
            box_encryption: true;
            separate_boxes_per_entity: true;
            compaction_strategy: "auto";
            max_size_per_box: "100MB";
            backup_enabled: true;
        };

        sqlite: {
            encryption: true;
            journal_mode: "WAL";
            auto_vacuum: "INCREMENTAL";
            secure_delete: true;
            foreign_keys: true;
        };
    };

    remote_storage: {
        supabase: {
            row_level_security: true;
            policies: {
                read: "authenticated_only";
                write: "authenticated_with_claims";
                delete: "admin_only";
            };
            backup_schedule: "daily";
            point_in_time_recovery: true;
            special_tables: {
                menu: {
                    exclude_from_sync: true;
                    backup_enabled: true;
                    allow_reset: true;
                    reset_procedure: {
                        backup_before_reset: true;
                        truncate_allowed: true;
                        auto_recreate: true;
                        preserve_structure: true;
                        notify_admins: true;
                    };
                    restore_procedure: {
                        from_backup: true;
                        validate_data: true;
                        notify_on_complete: true;
                    };
                };
            };
        };
    };

    data_synchronization: {
        strategy: "offline_first";
        conflict_resolution: {
            priority: "device_data";
            merge_strategy: "smart_merge";
            version_vectors: true;
            conflict_detection: true;
        };
        sync_rules: {
            prevent_data_override: true;
            validate_before_sync: true;
            backup_before_sync: true;
            retry_on_failure: true;
        };
        change_tracking: {
            track_modifications: true;
            version_history: true;
            audit_trail: true;
            change_notifications: true;
        };
    };

    migration_rules: {
        schema_changes: {
            version_control: true;
            backwards_compatible: true;
            data_preservation: true;
            rollback_support: true;
        };
        data_migration: {
            incremental: true;
            validate_integrity: true;
            preserve_existing: true;
            error_recovery: true;
        };
        testing: {
            dry_run: true;
            validation_checks: true;
            performance_impact: true;
            rollback_testing: true;
        };
    };

    monitoring: {
        performance: {
            query_analysis: true;
            index_usage: true;
            storage_metrics: true;
            sync_metrics: true;
        };
        security: {
            access_logs: true;
            change_logs: true;
            error_logs: true;
            sync_logs: true;
        };
        alerts: {
            storage_threshold: true;
            sync_failures: true;
            security_violations: true;
            performance_degradation: true;
        };
    };

    recovery: {
        auto_recovery: {
            enabled: true;
            max_attempts: 3;
            backoff_strategy: "exponential";
            notification: true;
        };
        manual_recovery: {
            guided_process: true;
            data_verification: true;
            partial_recovery: true;
            point_in_time: true;
        };
        disaster_recovery: {
            backup_location: "multiple";
            recovery_time_objective: "4h";
            recovery_point_objective: "24h";
            testing_schedule: "monthly";
        };
    };
};

## Log ve Hata Yönetimi Kuralları
logging_rules {
    logging_setup: {
        use_logging_package: true;
        avoid_print: true;
        avoid_debugPrint: true;
        log_levels: ["error", "warning", "info", "debug", "verbose"];
        default_level: "info";
    };

    log_configuration: {
        hierarchical_logging: false;
        record_stack_trace_at_level: "severe";
        color_output: true;
        log_format: {
            include_timestamp: true;
            include_level: true;
            include_logger_name: true;
            include_message: true;
            include_stacktrace: true;
        };
    };

    production_logging: {
        enabled: true;
        min_log_level: "warning";
        secure_logging: true;
        exclude_sensitive_data: true;
        log_rotation: {
            enabled: true;
            max_file_size: "10MB";
            max_files: 5;
        };
    };

    debug_logging: {
        enabled: true;
        console_output: true;
        file_output: true;
        network_logs: true;
        performance_logs: true;
        memory_logs: true;
    };

    error_handling: {
        global_error_handling: true;
        custom_error_widget: true;
        error_reporting: {
            enabled: true;
            include_device_info: true;
            include_app_info: true;
            include_error_details: true;
            sanitize_logs: true;
        };
        error_boundaries: {
            widget_errors: true;
            async_errors: true;
            platform_errors: true;
        };
    };

    monitoring: {
        performance_monitoring: true;
        error_monitoring: true;
        crash_reporting: true;
        analytics_integration: true;
    };

    best_practices: {
        use_structured_logging: true;
        log_sanitization: true;
        avoid_sensitive_data: true;
        proper_error_handling: true;
        proper_stack_trace_handling: true;
    };

    development_tools: {
        devtools_integration: true;
        console_filters: true;
        log_visualization: true;
        error_navigation: true;
    };
};

## Geliştirici Bilgisi
developer_info {
    name: "Ferhat NAS";
    role: "Baş Geliştirici";
    last_update: "2024-03-21";
}

## Dosya Bağlantı Şeması
file_connections {
    cursorrules: {
        description: "Projenin ana kural ve standart tanımlamalarını içeren yapılandırma dosyası";

        direct_connections: {
            analysis_options: {
                path: "analysis_options.yaml";
                relation: "Dart/Flutter lint ve analiz kurallarını yapılandırır";
                impact: "Kod kalitesi ve stil kontrolleri";
            };

            pubspec: {
                path: "pubspec.yaml";
                relation: "Paket bağımlılıkları ve proje yapılandırması";
                impact: "Proje bağımlılıkları ve yapılandırma ayarları";
            };

            lib_structure: {
                path: "lib/";
                relation: "Kaynak kod organizasyonu ve yapısı";
                impact: "Kod organizasyonu ve mimari yapı";
            };
        };

        module_connections: {
            core: {
                path: "lib/core/";
                relation: "Temel altyapı ve yardımcı sınıflar";
                enforced_rules: [
                    "turkish_documentation",
                    "code_style",
                    "error_handling"
                ];
            };

            features: {
                path: "lib/features/";
                relation: "Özellik modülleri";
                enforced_rules: [
                    "module_rules",
                    "state_management",
                    "ui_ux"
                ];
            };

            shared: {
                path: "lib/shared/";
                relation: "Paylaşılan bileşenler ve yardımcılar";
                enforced_rules: [
                    "component_rules",
                    "documentation",
                    "testing"
                ];
            };
        };

        test_connections: {
            unit_tests: {
                path: "test/unit/";
                relation: "Birim testleri";
                enforced_rules: ["testing_rules.unit_tests"];
            };

            widget_tests: {
                path: "test/widget/";
                relation: "Widget testleri";
                enforced_rules: ["testing_rules.widget_tests"];
            };

            integration_tests: {
                path: "test/integration/";
                relation: "Entegrasyon testleri";
                enforced_rules: ["testing_rules.integration_tests"];
            };
        };

        asset_connections: {
            images: {
                path: "assets/images/";
                relation: "Görsel varlıklar";
                enforced_rules: ["ui_ux.responsive_images"];
            };

            translations: {
                path: "assets/translations/";
                relation: "Çeviri dosyaları";
                enforced_rules: ["localization"];
            };

            fonts: {
                path: "assets/fonts/";
                relation: "Yazı tipleri";
                enforced_rules: ["ui_ux.typography"];
            };
        };

        platform_connections: {
            android: {
                path: "android/";
                relation: "Android platform konfigürasyonu";
                enforced_rules: ["mobile_app.platform_specific.android"];
            };

            ios: {
                path: "ios/";
                relation: "iOS platform konfigürasyonu";
                enforced_rules: ["mobile_app.platform_specific.ios"];
            };

            web: {
                path: "web/";
                relation: "Web platform konfigürasyonu";
                enforced_rules: ["responsive_design"];
            };

            desktop: {
                paths: ["windows/", "macos/", "linux/"];
                relation: "Masaüstü platform konfigürasyonları";
                enforced_rules: ["desktop_specific"];
            };
        };

        documentation_connections: {
            api_docs: {
                path: "docs/api/";
                relation: "API dokümantasyonu";
                enforced_rules: ["documentation_rules"];
            };

            user_guides: {
                path: "docs/guides/";
                relation: "Kullanıcı kılavuzları";
                enforced_rules: ["documentation_generator.user_documentation"];
            };

            developer_docs: {
                path: "docs/development/";
                relation: "Geliştirici dokümantasyonu";
                enforced_rules: ["documentation_generator.developer_documentation"];
            };
        };

        script_connections: {
            analysis: {
                path: "scripts/analysis/";
                relation: "Kod analiz scriptleri";
                enforced_rules: ["script_rules.analysis_scripts"];
            };

            testing: {
                path: "scripts/testing/";
                relation: "Test otomasyonu scriptleri";
                enforced_rules: ["script_rules.test_scripts"];
            };

            deployment: {
                path: "scripts/deployment/";
                relation: "Dağıtım ve yayınlama scriptleri";
                enforced_rules: ["script_rules.automation_scripts"];
            };
        };

        monitoring_connections: {
            logs: {
                path: "logs/";
                relation: "Uygulama logları";
                enforced_rules: ["logging_rules"];
            };

            analytics: {
                path: "analytics/";
                relation: "Analitik verileri";
                enforced_rules: ["monitoring"];
            };

            performance: {
                path: "performance/";
                relation: "Performans metrikleri";
                enforced_rules: ["performance_rules"];
            };
        };
    };
};

## Otomatik Çalıştırma Kuralları
auto_run_rules {
    device_priority: {
        check_connected_devices: true;
        priority_order: ["mobile", "windows"];

        mobile_device: {
            enabled: true;
            auto_select: true;
            platform_preference: ["android", "ios"];
            command: "flutter run -d {device_id}";
            fallback: "windows";
        };

        windows_device: {
            enabled: true;
            command: "flutter run -d windows";
            window_settings: {
                width: 1280;
                height: 720;
                position: "center";
                title: "EXFINERP";
            };
        };

        device_detection: {
            check_interval: "2s";
            timeout: "30s";
            retry_attempts: 3;
            auto_reload: true;
        };

        error_handling: {
            device_not_found: {
                action: "fallback_to_windows";
                notification: true;
                log_error: true;
            };
            launch_failed: {
                retry: true;
                max_retries: 3;
                fallback_action: "show_error_dialog";
            };
        };

        performance_monitoring: {
            startup_time: true;
            memory_usage: true;
            frame_rate: true;
            report_issues: true;
        };

        development_mode: {
            hot_reload: true;
            debug_mode: true;
            network_logging: true;
            performance_overlay: false;
        };

        notifications: {
            device_connected: true;
            device_disconnected: true;
            build_started: true;
            build_completed: true;
            errors: true;
        };
    };
};

## Senkronizasyon Onay Kuralları
sync_approval_rules {
    approval_field: {
        name: "ONAY";
        type: "INTEGER";
        default_value: 0;
        states: {
            pending: 0;      // Beklemede
            approved: 1;     // Onaylandı
            synced: 2;       // Senkronize Edildi
            rejected: 3;     // Reddedildi
            error: 4;        // Hata
        };
    };

    sync_conditions: {
        only_approved: true;
        approval_check: "ONAY = 1";
        post_sync_state: 2;
        error_state: 4;
    };

    table_requirements: {
        mandatory_fields: [
            "ONAY",
            "created_at",
            "updated_at",
            "is_synced",
            "is_deleted"
        ];
        field_types: {
            ONAY: "INTEGER NOT NULL DEFAULT 0",
                created_at: "TEXT NOT NULL",
                    updated_at: "TEXT NOT NULL",
                        is_synced: "INTEGER NOT NULL DEFAULT 0",
                            is_deleted: "INTEGER NOT NULL DEFAULT 0"
        };
    };

    triggers: {
        before_sync: {
            check_approval: true;
            backup_data: true;
            validate_fields: true;
        };
        after_sync: {
            update_status: true;
            log_sync: true;
            notify_users: true;
        };
        on_error: {
            rollback: true;
            log_error: true;
            notify_admin: true;
            retry_count: 3;
        };
    };

    logging: {
        enabled: true;
        log_fields: [
            "table_name",
            "record_id",
            "old_status",
            "new_status",
            "sync_date",
            "sync_user",
            "error_message"
        ];
        retention_days: 30;
    };

    notifications: {
        on_approval: true;
        on_sync: true;
        on_error: true;
        channels: ["system", "email"];
    };

    security: {
        role_based_approval: true;
        audit_trail: true;
        encryption: true;
        data_validation: true;
    };
};

## Windows Geliştirme Sembolik Bağlantı Kuralları
windows_development {
    symlink_handling: {
        problem: "Windows'ta Flutter sembolik bağlantı (symlink) oluşturma hatası";
        solution: {
            developer_mode: {
                required: true;
                setup_instructions: "Windows Ayarları > Geliştirici için > Geliştirici Modu'nu açın";
            };
            admin_privileges: {
                required: true;
                explanation: "Flutter geliştirme ortamı sembolik bağlantılar oluşturabilmek için yönetici haklarına ihtiyaç duyar";
            };
            flutter_clean: {
                command: "flutter clean";
                explanation: "Mevcut hatalı sembolik bağlantıları temizler";
            };
            cache_repair: {
                command: "flutter pub cache repair";
                explanation: "Bozuk paket önbelleklerini düzeltir";
            };
            powershell_commands: {
                admin_execution: "Powershell'i yönetici olarak çalıştırın";
                enable_symlinks: "Set-ExecutionPolicy -ExecutionPolicy RemoteSigned -Scope CurrentUser";
                command_explanation: "PowerShell betik çalıştırma politikasını düzenler";
            };
            project_reset: {
                steps: [
                    "flutter clean",
                    "rmdir /S /Q windows\\flutter\\ephemeral",
                    "flutter pub get",
                    "flutter run -d windows"
                ];
                explanation: "Windows plugin sembolik bağlantılarını yeniden oluşturur";
            };
            git_config: {
                command: "git config --global core.symlinks true";
                explanation: "Git'in sembolik bağlantıları düzgün şekilde işlemesini sağlar";
            };
        };
        prevention: {
            always_run_as_admin: true;
            keep_developer_mode_on: true;
            use_git_bash: true;
            prefer_wsl: {
                description: "Geliştirme için Windows Subsystem for Linux kullanmak sembolik bağlantı sorunlarını ortadan kaldırabilir";
                setup: "Windows Özelliklerini Aç Kapat > WSL'i etkinleştir > Microsoft Store'dan Ubuntu kur";
            };
        };
    };

    error_recovery: {
        app_links_error: {
            symptoms: "PathExistsException: Cannot create link, path = '.../.plugin_symlinks/app_links'";
            fix_steps: [
                "Powershell'i yönetici olarak çalıştır",
                "cd [proje_dizini]",
                "rmdir /S /Q windows\\flutter\\ephemeral",
                "flutter clean",
                "flutter pub get",
                "flutter run -d windows"
            ];
            preventive_measures: [
                "Windows Geliştirici Modunu etkinleştir",
                "IDE'yi her zaman yönetici olarak çalıştır",
                "pubspec.yaml değişikliklerinden sonra windows\\flutter\\ephemeral klasörünü temizle"
            ];
        };
    };

    windows_ide_setup: {
        visual_studio_code: {
            run_as_admin: true;
            workspace_settings: {
                terminal_settings: {
                    windows_shell: "C:\\Windows\\System32\\cmd.exe";
                    shell_args: ["/K", "\"C:\\Program Files\\PowerShell\\7\\pwsh.exe\""];
                };
            };
        };
        android_studio: {
            run_as_admin: true;
            vm_options: "-Djava.io.tmpdir=C:\\Windows\\Temp";
        };
        cursor: {
            run_as_admin: true;
        };
    };
}; 